# Este archivo documenta las variables que necesita el server de producción.
# NO se commitea el .env real — se crea a mano una sola vez en /home/ubuntu/signit/.env
# (git nunca lo toca porque está en .gitignore, así que sobrevive a cada deploy).

DATABASE_URL="postgresql://postgres.xvydhljegeuhqnexvwgj:<db-password>@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

AUTH_SECRET="<generar uno nuevo con: openssl rand -base64 32 — NO reusar el de dev>"
# Obligatorio detrás de un reverse proxy (Traefik): sin esto, Auth.js arma los
# links de magic link y los redirects de login/logout con la dirección interna
# donde escucha el proceso (localhost:PORT) en vez del dominio público.
AUTH_URL="https://signit.signai.ar"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# SMTP de Brevo. El login de Brevo trae un "@" adentro — hay que URL-encodearlo
# (%40) o nodemailer rompe el parseo user:pass@host. La clave no tiene
# caracteres especiales, no necesita encoding.
EMAIL_SERVER="smtp://<login-urlencoded>:<key>@smtp-relay.brevo.com:587"
EMAIL_FROM="SignIT <updates@signai.ar>"

PORT=8711

# Directorio persistente para los archivos subidos (takes crudos). No debe
# vivir dentro de APP_DIR si en algún momento se hace deploy con un checkout
# limpio; con el flujo actual (git pull sobre el mismo directorio) alcanza
# con que quede fuera del control de git.
UPLOADS_DIR="/home/ubuntu/signit-uploads"
