# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# Supabase Postgres. Project: SignIT (xvydhljegeuhqnexvwgj, us-east-1).
# Use the SESSION pooler (port 5432, aws-0-<region>.pooler.supabase.com), not the
# direct db.<ref>.supabase.co host — that one is IPv6-only and won't resolve from
# most local networks. Get the password from Project Settings > Database in Supabase.
DATABASE_URL="postgresql://postgres.xvydhljegeuhqnexvwgj:<db-password>@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Auth.js
AUTH_SECRET="dev-secret-change-me-CHANGE-IN-PROD"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Necesario para el proveedor de email (magic link). Vacío = deshabilitado en dev.
EMAIL_SERVER=""
EMAIL_FROM="SignIT <no-reply@signit.dev>"