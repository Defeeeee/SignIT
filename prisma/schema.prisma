// SignIT — modelo de datos (spec sección 3)
// generator/config siguen las convenciones de Prisma 7 (ver prisma.config.ts)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Enums ----------

enum Rol {
  USUARIO
  MODERADOR
  ADMIN
}

enum VideoOrigen {
  YOUTUBE
  PROPIO
  CREATIVE_COMMONS
}

enum VideoEstado {
  ACTIVO
  HUERFANO // el video original fue borrado/privado en YouTube (riesgo sección 12)
  BLOQUEADO
}

enum ModoPublicacion {
  AVATAR
  VIDEO_REAL
}

// Estados de un clip — spec 3.1
enum ClipEstado {
  GRABANDO
  BORRADOR
  VALIDADO
  EN_REVISION
  PUBLICADO
  RECHAZADO
}

enum HuecoEstado {
  DETECTADO
  PERMITIDO // pausa real en el audio original (Whisper) — regla 5.1
  RESUELTO
}

enum PedidoEstado {
  ABIERTO
  CUMPLIDO
  CERRADO
}

enum TipoComentario {
  TEXTO
  SENA
}

enum ReporteEstado {
  ABIERTO
  EN_REVISION
  RESUELTO
  DESESTIMADO
}

// ---------- Auth.js (NextAuth) ----------
// Nombres de modelo requeridos por @auth/prisma-adapter.
// "User" es la entidad "Usuario" de la spec (sección 3) con los campos de dominio incluidos.

model User {
  id            String    @id @default(cuid())
  handle        String    @unique
  nombre        String
  email         String    @unique
  emailVerified DateTime?
  image         String?

  rol                     Rol     @default(USUARIO)
  senanteVerificado       Boolean @default(false)
  region                  String? // provincia — variación regional de LSA
  storageUsedMb           Int     @default(0)
  storageQuotaMb          Int     @default(20000) // 20 GB, spec 2/4.1 (en MB para evitar BigInt)
  consentimientoDataset   Boolean @default(false)
  consentimientoBiometria Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts         Account[]
  sessions         Session[]
  videosSubidos    Video[]
  interpretaciones Interpretacion[]
  pedidos          Pedido[]
  pedidoVotos      PedidoVoto[]
  comentarios      Comentario[]
  descargas        Descarga[]
  reportes         Reporte[]

  @@map("usuarios")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Dominio ----------

model Video {
  id               String      @id @default(cuid())
  origen           VideoOrigen
  youtubeId        String?
  archivoUrl       String?
  titulo           String
  canal            String?
  duracionSegundos Int
  categoria        String?
  hashtags         String[]    @default([])
  idioma           String      @default("es")
  estado           VideoEstado @default(ACTIVO)

  subidoPorId String?
  subidoPor   User?   @relation(fields: [subidoPorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  interpretaciones Interpretacion[]
  pedidos          Pedido[]
  comentarios      Comentario[]
  reportes         Reporte[]

  @@index([estado])
}

model Interpretacion {
  id              String          @id @default(cuid())
  videoId         String
  video           Video           @relation(fields: [videoId], references: [id], onDelete: Cascade)
  usuarioId       String
  usuario         User            @relation(fields: [usuarioId], references: [id])
  modoPublicacion ModoPublicacion

  // % del video cubierto por clips publicados de esta interpretación
  coberturaAgregada Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clips Clip[]

  @@index([videoId])
  @@index([usuarioId])
}

model Clip {
  id               String         @id @default(cuid())
  interpretacionId String
  interpretacion   Interpretacion @relation(fields: [interpretacionId], references: [id], onDelete: Cascade)

  tInicio Float // rango [t_inicio, t_fin] sobre el video original
  tFin    Float

  estado ClipEstado @default(GRABANDO)

  // posición y tamaño por defecto del recuadro del intérprete (espectador puede sobreescribir)
  posX  Float @default(0.75)
  posY  Float @default(0.65)
  ancho Float @default(0.2)
  alto  Float @default(0.3)

  hashtags      String[] @default([])
  vistas        Int      @default(0)
  motivoRechazo String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  takes       Take[]
  huecos      Hueco[]
  comentarios Comentario[]
  descargas   Descarga[]
  reportes    Reporte[]
  pedidos     PedidoClip[]

  @@index([interpretacionId])
  @@index([estado])
}

model Take {
  id     String @id @default(cuid())
  clipId String
  clip   Clip   @relation(fields: [clipId], references: [id], onDelete: Cascade)

  rangoInicio Float
  rangoFin    Float

  archivoCrudoUrl       String
  archivoRenderUrl      String?
  velocidadReproduccion Float   @default(1.0)
  syncOffsetMs          Int     @default(0)

  createdAt DateTime @default(now())

  keypoints Keypoints?

  @@index([clipId])
}

model Keypoints {
  id     String @id @default(cuid())
  takeId String @unique
  take   Take   @relation(fields: [takeId], references: [id], onDelete: Cascade)

  // series temporales grandes -> objeto en blob storage, no en la fila
  landmarksUrl    String
  modeloVersion   String
  confidenceScore Float
  personaValida   Boolean @default(true)
  flagsActividad  Json?

  createdAt DateTime @default(now())
}

model Hueco {
  id     String @id @default(cuid())
  clipId String
  clip   Clip   @relation(fields: [clipId], references: [id], onDelete: Cascade)

  tA     Float
  tB     Float
  estado HuecoEstado @default(DETECTADO)

  createdAt DateTime @default(now())

  @@index([clipId])
}

model Pedido {
  id      String       @id @default(cuid())
  autorId String
  autor   User         @relation(fields: [autorId], references: [id])
  videoId String?
  video   Video?       @relation(fields: [videoId], references: [id])
  tema    String?
  estado  PedidoEstado @default(ABIERTO)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  votos PedidoVoto[]
  clips PedidoClip[]

  @@index([estado])
}

model PedidoVoto {
  pedidoId String
  pedido   Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([pedidoId, userId])
}

model PedidoClip {
  pedidoId String
  pedido   Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  clipId   String
  clip     Clip   @relation(fields: [clipId], references: [id], onDelete: Cascade)

  @@id([pedidoId, clipId])
}

model Comentario {
  id      String @id @default(cuid())
  autorId String
  autor   User   @relation(fields: [autorId], references: [id])

  videoId String?
  video   Video?  @relation(fields: [videoId], references: [id], onDelete: Cascade)
  clipId  String?
  clip    Clip?   @relation(fields: [clipId], references: [id], onDelete: Cascade)

  tipo              TipoComentario
  contenidoTexto    String?
  contenidoVideoUrl String?

  parentId String?
  parent   Comentario?  @relation("hilo", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  hijos    Comentario[] @relation("hilo")

  createdAt DateTime @default(now())

  @@index([videoId])
  @@index([clipId])
}

model Descarga {
  id        String   @id @default(cuid())
  usuarioId String
  usuario   User     @relation(fields: [usuarioId], references: [id])
  clipId    String
  clip      Clip     @relation(fields: [clipId], references: [id])
  createdAt DateTime @default(now())

  @@index([usuarioId, createdAt]) // para el límite de 2 descargas / 3hs
}

model Reporte {
  id      String @id @default(cuid())
  autorId String
  autor   User   @relation(fields: [autorId], references: [id])

  videoId String?
  video   Video?  @relation(fields: [videoId], references: [id], onDelete: Cascade)
  clipId  String?
  clip    Clip?   @relation(fields: [clipId], references: [id], onDelete: Cascade)

  motivo         String
  estado         ReporteEstado @default(ABIERTO)
  resolucionNota String?

  createdAt DateTime @default(now())

  @@index([estado])
}
